# Google Cloud Project Configuration
PROJECT_ID=your-google-cloud-project-id
CLIENT_ID=your-google-oauth-client-id
CLIENT_SECRET=your-google-oauth-client-secret
REDIRECT_URI=http://localhost:3000/auth/callback

# ── Gemini AI (required for agentic features) ─────────────────────────────────
# Get a free API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key
# Primary model to use (recommended for free tier stability)
GEMINI_MODEL=gemini-2.0-flash-lite
# Optional comma-separated fallback models used when primary is rate-limited
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-pro-latest

# Google Chat Bot Configuration
CHAT_BOT_EMAIL=your-bot-email@domain.iam.gserviceaccount.com
CHAT_BOT_NAME=AgenticAI-Calendar-Bot
GOOGLE_CHAT_VERIFICATION_TOKEN=your-google-chat-verification-token

# Base URL used to generate OAuth/auth links returned to Google Chat users
# Example local: http://localhost:3000
# Example prod: https://your-cloud-run-url.a.run.app
APP_BASE_URL=http://localhost:3000

# Fallback host used when APP_BASE_URL is not set
WEBHOOK_HOST=localhost:3000

# Server Configuration
PORT=3000
NODE_ENV=development

# API Scopes (space-separated)
GOOGLE_SCOPES=https://www.googleapis.com/auth/calendar.readonly https://www.googleapis.com/auth/gmail.readonly https://www.googleapis.com/auth/drive.readonly

# Storage/Database Configuration
STORAGE_TYPE=memory
# For production, use: firestore, mongodb, etc.
FIRESTORE_DATABASE=your-firestore-database-id
